rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email']) &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL']);
    }

    // --- Statuses ---
    match /statuses/{statusId} {
      function isValidStatus(data) {
        return data.content is string && data.content.size() <= 500 &&
               data.authorId == request.auth.uid &&
               data.anonymousName is string &&
               data.createdAt == request.time;
      }

      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn() && isValidStatus(request.resource.data);
      // No updates or deletes for now to keep it simple and secure as a feed
    }

    // --- Journal Entries ---
    match /journal_entries/{entryId} {
      function isValidEntry(data) {
        return data.userId == request.auth.uid &&
               data.content is string && 
               data.content.size() <= 2000;
      }

      allow list: if isSignedIn(); // Filtered by query in client
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidEntry(request.resource.data);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
